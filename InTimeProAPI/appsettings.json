{
  "ConnectionStrings": {
    "DefaultConnection": "Server=(localdb)\\mssqllocaldb;Database=InTimeProDB;Trusted_Connection=True;MultipleActiveResultSets=true;Encrypt=True;TrustServerCertificate=False;Max Pool Size=100;"
  },
  "JwtSettings": {
    "SecretKey": "InTimePro-Super-Secret-Key-2026-WAI-Technologies-Must-Be-32-Chars-Min",
    "Issuer": "InTimeProAPI",
    "Audience": "InTimeProMobileApp",
    "AccessTokenExpiryMinutes": 60,
    "RefreshTokenExpiryDays": 30
  },
  "GoogleAuth": {
    "ClientId": "YOUR_GOOGLE_CLIENT_ID",
    "ClientSecret": "YOUR_GOOGLE_CLIENT_SECRET"
  },
  "MicrosoftAuth": {
    "ClientId": "YOUR_MICROSOFT_CLIENT_ID",
    "ClientSecret": "YOUR_MICROSOFT_CLIENT_SECRET",
    "TenantId": "YOUR_TENANT_ID"
  },
  "Alerts": {
    "FailedLogin": "Security",
    "OverdueTask": "Operations",
    "TimesheetSubmissionFailed": "Operations"
  },
  "DataRetention": {
    "EmployeeAuditMonths": 24,
    "EmployeePiiRetentionMonths": 36
  },
  "Secrets": {
    "Provider": "environment",
    "JwtSecretRef": "INTIMEPRO_JWT_SECRET",
    "GoogleClientSecretRef": "INTIMEPRO_GOOGLE_CLIENT_SECRET",
    "MicrosoftClientSecretRef": "INTIMEPRO_MICROSOFT_CLIENT_SECRET"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "InTimeProAPI": "Information"
    }
  },
  "AllowedHosts": "*"
}
